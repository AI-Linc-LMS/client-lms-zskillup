# ZSkillup Frontend — environment template. Copy to `.env.local`.
# Only NEXT_PUBLIC_* vars are exposed to the browser.

# Base URL the browser uses to reach the API (used by lib/api/client.ts).
# - Local dev: point straight at the local backend.
# - Production (Netlify): set to the SITE's own origin so API calls are
#   same-origin and get proxied to the backend by the next.config.ts rewrite
#   (keeps the HttpOnly refresh cookie first-party). e.g.
#   NEXT_PUBLIC_API_URL=https://zskillup-lms.netlify.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# Production only (Netlify). Origin of the backend ALB that the server-side
# rewrite in next.config.ts proxies /api/v1/* to. Leave UNSET for local dev.
# e.g. BACKEND_ORIGIN=http://zskillup-load-balancer-122235018.ap-south-1.elb.amazonaws.com
# BACKEND_ORIGIN=

# Google OAuth — client ID for the Sign in with Google button.
# Must match OAUTH_CLIENT_ID in the backend .env.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
